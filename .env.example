# ==========================================
# ArenaFlow AI - Environment Configuration Example
# ==========================================

# 1. Google Gemini GenAI API Key (Server-Side Proxy Client Secret)
VITE_GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"

# 2. Local/Production API Routing Configuration
VITE_API_URL="http://localhost:3000"

# 3. Crowd Density Real-Time Simulation Settings
VITE_SIMULATION_ENABLED="true"
VITE_SIMULATION_INTERVAL="3000" # Milliseconds

# 4. Host deployment metadata
APP_URL="http://localhost:3000"
